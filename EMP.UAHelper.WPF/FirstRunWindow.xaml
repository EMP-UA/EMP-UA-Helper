<!-- UA: Вікно першого запуску — налаштування API ключів
     EN: First run window — API keys configuration -->
<Window x:Class="EMP.UAHelper.WPF.FirstRunWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Height="940" Width="620"
        MinHeight="760" MinWidth="580"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="#0D0A14">

    <Window.Resources>
        <Style x:Key="GroupLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#8A46C1"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,24,0,2"/>
        </Style>

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#C989F3"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E8E0F0"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,12,0,3"/>
        </Style>

        <Style x:Key="FieldHint" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#B8A8D0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,3"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="InputField" TargetType="TextBox">
            <Setter Property="Background" Value="#1A1425"/>
            <Setter Property="Foreground" Value="#E8E0F0"/>
            <Setter Property="BorderBrush" Value="#3D2B5E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="SelectionBrush" Value="#8A46C1"/>
        </Style>

        <!-- UA: Той самий вигляд що й InputField, але для PasswordBox — маскування секретів
             EN: Same look as InputField but for PasswordBox — secret masking -->
        <Style x:Key="SecureInputField" TargetType="PasswordBox">
            <Setter Property="Background" Value="#1A1425"/>
            <Setter Property="Foreground" Value="#E8E0F0"/>
            <Setter Property="BorderBrush" Value="#3D2B5E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="SelectionBrush" Value="#8A46C1"/>
        </Style>

        <Style x:Key="RevealButton" TargetType="Button">
            <Setter Property="Background" Value="#1A1425"/>
            <Setter Property="Foreground" Value="#C989F3"/>
            <Setter Property="BorderBrush" Value="#3D2B5E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Width" Value="42"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3D2B5E"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="EmpButton" TargetType="Button">
            <Setter Property="Background" Value="#8A46C1"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="24,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#C989F3"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="LangButton" TargetType="Button">
            <Setter Property="Background" Value="#1A1425"/>
            <Setter Property="Foreground" Value="#C989F3"/>
            <Setter Property="BorderBrush" Value="#8A46C1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3D2B5E"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SectionCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#B8A8D0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Bottom"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,20,28,24">

            <!-- UA: Заголовок і перемикач мови
                 EN: Header and language switcher -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="TxtWelcome"
                           Grid.Column="0"
                           Foreground="#C989F3" FontSize="20" FontWeight="Bold"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="8,0,0,0">
                    <Button x:Name="BtnUA" Content="🇺🇦 UA"
                            Style="{StaticResource LangButton}"
                            Margin="0,0,4,0"
                            Click="BtnUA_Click"/>
                    <Button x:Name="BtnEN" Content="🇬🇧 EN"
                            Style="{StaticResource LangButton}"
                            Click="BtnEN_Click"/>
                </StackPanel>
            </Grid>

            <TextBlock x:Name="TxtDescription"
                       Foreground="#B8A8D0" FontSize="14" Margin="0,6,0,4"
                       TextWrapping="Wrap"/>

            <!-- UA: Група — ДЖЕРЕЛА КОНТЕНТУ
                 EN: Group — CONTENT SOURCES -->
            <TextBlock x:Name="TxtGroupContent" Style="{StaticResource GroupLabel}"/>

            <!-- YOUTUBE -->
            <Grid Margin="0,4,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="TxtSectionYoutube" Grid.Column="0" Style="{StaticResource SectionLabel}"/>
                <CheckBox x:Name="ChkUseYoutube" Grid.Column="1"
                          Style="{StaticResource SectionCheckBox}"
                          Checked="ChkUseYoutube_Changed" Unchecked="ChkUseYoutube_Changed"/>
            </Grid>
            <Rectangle Height="1" Fill="#3D2B5E" Margin="0,4,0,0"/>

            <StackPanel x:Name="PanelYoutube">
                <TextBlock x:Name="TxtYtKey" Style="{StaticResource FieldLabel}"/>
                <TextBlock x:Name="TxtYtKeyHint" Style="{StaticResource FieldHint}"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <PasswordBox x:Name="YoutubeKeySecure" Grid.Column="0" Style="{StaticResource SecureInputField}"/>
                    <TextBox x:Name="YoutubeKeyPlain" Grid.Column="0" Style="{StaticResource InputField}" Visibility="Collapsed"/>
                    <Button x:Name="BtnToggleYoutubeKey" Grid.Column="1" Content="👁" Style="{StaticResource RevealButton}"
                            Click="ToggleYoutubeKey_Click"/>
                </Grid>

                <TextBlock x:Name="TxtYtChannelId" Style="{StaticResource FieldLabel}"/>
                <TextBlock x:Name="TxtYtChannelIdHint" Style="{StaticResource FieldHint}"/>
                <TextBox x:Name="YoutubeChannelId" Style="{StaticResource InputField}"/>
            </StackPanel>

            <!-- TWITCH -->
            <Grid Margin="0,20,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="TxtSectionTwitch" Grid.Column="0" Style="{StaticResource SectionLabel}"/>
                <CheckBox x:Name="ChkUseTwitch" Grid.Column="1"
                          Style="{StaticResource SectionCheckBox}"
                          Checked="ChkUseTwitch_Changed" Unchecked="ChkUseTwitch_Changed"/>
            </Grid>
            <Rectangle Height="1" Fill="#3D2B5E" Margin="0,4,0,0"/>

            <StackPanel x:Name="PanelTwitch">
                <TextBlock x:Name="TxtTwUrl" Style="{StaticResource FieldLabel}"/>
                <TextBlock x:Name="TxtTwUrlHint" Style="{StaticResource FieldHint}"/>
                <TextBox x:Name="TwitchUrl" Style="{StaticResource InputField}"
                         Text="https://www.twitch.tv/"/>
            </StackPanel>

            <!-- UA: Група — ПЛАТФОРМИ СПОВІЩЕНЬ
                 EN: Group — NOTIFICATION PLATFORMS -->
            <TextBlock x:Name="TxtGroupNotify" Style="{StaticResource GroupLabel}"/>

            <!-- TELEGRAM -->
            <Grid Margin="0,4,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="TxtSectionTelegram" Grid.Column="0" Style="{StaticResource SectionLabel}"/>
                <CheckBox x:Name="ChkUseTelegram" Grid.Column="1"
                          Style="{StaticResource SectionCheckBox}"
                          Checked="ChkUseTelegram_Changed" Unchecked="ChkUseTelegram_Changed"/>
            </Grid>
            <Rectangle Height="1" Fill="#3D2B5E" Margin="0,4,0,0"/>

            <StackPanel x:Name="PanelTelegram">
                <TextBlock x:Name="TxtTgToken" Style="{StaticResource FieldLabel}"/>
                <TextBlock x:Name="TxtTgTokenHint" Style="{StaticResource FieldHint}"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <PasswordBox x:Name="TelegramTokenSecure" Grid.Column="0" Style="{StaticResource SecureInputField}"/>
                    <TextBox x:Name="TelegramTokenPlain" Grid.Column="0" Style="{StaticResource InputField}" Visibility="Collapsed"/>
                    <Button x:Name="BtnToggleTelegramToken" Grid.Column="1" Content="👁" Style="{StaticResource RevealButton}"
                            Click="ToggleTelegramToken_Click"/>
                </Grid>

                <TextBlock x:Name="TxtTgChannel" Style="{StaticResource FieldLabel}"/>
                <TextBlock x:Name="TxtTgChannelHint" Style="{StaticResource FieldHint}"/>
                <TextBox x:Name="TelegramChannel" Style="{StaticResource InputField}"
                         Text="@"/>
            </StackPanel>

            <!-- DISCORD -->
            <Grid Margin="0,20,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="TxtSectionDiscord" Grid.Column="0" Style="{StaticResource SectionLabel}"/>
                <CheckBox x:Name="ChkUseDiscord" Grid.Column="1"
                          Style="{StaticResource SectionCheckBox}"
                          Checked="ChkUseDiscord_Changed" Unchecked="ChkUseDiscord_Changed"/>
            </Grid>
            <Rectangle Height="1" Fill="#3D2B5E" Margin="0,4,0,0"/>

            <StackPanel x:Name="PanelDiscord">
                <TextBlock x:Name="TxtDcWebhook" Style="{StaticResource FieldLabel}"/>
                <TextBlock x:Name="TxtDcWebhookHint" Style="{StaticResource FieldHint}"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <PasswordBox x:Name="DiscordWebhookSecure" Grid.Column="0" Style="{StaticResource SecureInputField}"/>
                    <TextBox x:Name="DiscordWebhookPlain" Grid.Column="0" Style="{StaticResource InputField}" Visibility="Collapsed"/>
                    <Button x:Name="BtnToggleDiscordWebhook" Grid.Column="1" Content="👁" Style="{StaticResource RevealButton}"
                            Click="ToggleDiscordWebhook_Click"/>
                </Grid>

                <TextBlock x:Name="TxtDcRoleId" Style="{StaticResource FieldLabel}"/>
                <TextBlock x:Name="TxtDcRoleIdHint" Style="{StaticResource FieldHint}"/>
                <TextBox x:Name="DiscordRoleId" Style="{StaticResource InputField}"/>
            </StackPanel>

            <!-- UA: Кнопка збереження / EN: Save button -->
            <Button x:Name="BtnSave"
                    Style="{StaticResource EmpButton}"
                    Margin="0,28,0,0" HorizontalAlignment="Right"
                    Click="BtnSave_Click"/>

        </StackPanel>
    </ScrollViewer>
</Window>