<!-- UA: Вікно першого запуску — налаштування API ключів
     EN: First run window — API keys configuration -->
<Window x:Class="EMP.UAHelper.WPF.FirstRunWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Height="860" Width="620"
        MinHeight="760" MinWidth="580"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="#0D0A14">

    <Window.Resources>
        <Style TargetType="TabItem">
            <Setter Property="Background" Value="#1A1425"/>
            <Setter Property="Foreground" Value="#B8A8D0"/>
            <Setter Property="BorderBrush" Value="#3D2B5E"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="FontSize" Value="14"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#3D2B5E"/>
                    <Setter Property="Foreground" Value="#C989F3"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#C989F3"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#C989F3"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E8E0F0"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,12,0,3"/>
        </Style>

        <Style x:Key="FieldHint" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#B8A8D0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,3"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="InputField" TargetType="TextBox">
            <Setter Property="Background" Value="#1A1425"/>
            <Setter Property="Foreground" Value="#E8E0F0"/>
            <Setter Property="BorderBrush" Value="#3D2B5E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="SelectionBrush" Value="#8A46C1"/>
        </Style>

        <Style x:Key="EmpButton" TargetType="Button">
            <Setter Property="Background" Value="#8A46C1"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="24,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#C989F3"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="LangButton" TargetType="Button">
            <Setter Property="Background" Value="#1A1425"/>
            <Setter Property="Foreground" Value="#C989F3"/>
            <Setter Property="BorderBrush" Value="#8A46C1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3D2B5E"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,20,28,24">

            <!-- UA: Заголовок і перемикач мови
                 EN: Header and language switcher -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="TxtWelcome"
                           Grid.Column="0"
                           Foreground="#C989F3" FontSize="20" FontWeight="Bold"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="8,0,0,0">
                    <Button x:Name="BtnUA" Content="🇺🇦 UA"
                            Style="{StaticResource LangButton}"
                            Margin="0,0,4,0"
                            Click="BtnUA_Click"/>
                    <Button x:Name="BtnEN" Content="🇬🇧 EN"
                            Style="{StaticResource LangButton}"
                            Click="BtnEN_Click"/>
                </StackPanel>
            </Grid>

            <TextBlock x:Name="TxtDescription"
                       Foreground="#B8A8D0" FontSize="14" Margin="0,6,0,20"
                       TextWrapping="Wrap"/>

            <!-- TELEGRAM -->
            <TextBlock x:Name="TxtSectionTelegram" Style="{StaticResource SectionLabel}"/>
            <Rectangle Height="1" Fill="#3D2B5E" Margin="0,4,0,0"/>

            <TextBlock x:Name="TxtTgToken" Style="{StaticResource FieldLabel}"/>
            <TextBlock x:Name="TxtTgTokenHint" Style="{StaticResource FieldHint}"/>
            <TextBox x:Name="TelegramToken" Style="{StaticResource InputField}"/>

            <TextBlock x:Name="TxtTgChannel" Style="{StaticResource FieldLabel}"/>
            <TextBlock x:Name="TxtTgChannelHint" Style="{StaticResource FieldHint}"/>
            <TextBox x:Name="TelegramChannel" Style="{StaticResource InputField}"
                     Text="@"/>

            <!-- YOUTUBE -->
            <TextBlock x:Name="TxtSectionYoutube" Style="{StaticResource SectionLabel}"
                       Margin="0,20,0,0"/>
            <Rectangle Height="1" Fill="#3D2B5E" Margin="0,4,0,0"/>

            <TextBlock x:Name="TxtYtKey" Style="{StaticResource FieldLabel}"/>
            <TextBlock x:Name="TxtYtKeyHint" Style="{StaticResource FieldHint}"/>
            <TextBox x:Name="YoutubeKey" Style="{StaticResource InputField}"/>

            <TextBlock x:Name="TxtYtChannelId" Style="{StaticResource FieldLabel}"/>
            <TextBlock x:Name="TxtYtChannelIdHint" Style="{StaticResource FieldHint}"/>
            <TextBox x:Name="YoutubeChannelId" Style="{StaticResource InputField}"/>

            <!-- DISCORD -->
            <TextBlock x:Name="TxtSectionDiscord" Style="{StaticResource SectionLabel}"
                       Margin="0,20,0,0"/>
            <Rectangle Height="1" Fill="#3D2B5E" Margin="0,4,0,0"/>

            <TextBlock x:Name="TxtDcWebhook" Style="{StaticResource FieldLabel}"/>
            <TextBlock x:Name="TxtDcWebhookHint" Style="{StaticResource FieldHint}"/>
            <TextBox x:Name="DiscordWebhook" Style="{StaticResource InputField}"
                     Text="https://discord.com/api/webhooks/"/>

            <TextBlock x:Name="TxtDcRoleId" Style="{StaticResource FieldLabel}"/>
            <TextBlock x:Name="TxtDcRoleIdHint" Style="{StaticResource FieldHint}"/>
            <TextBox x:Name="DiscordRoleId" Style="{StaticResource InputField}"/>

            <!-- TWITCH -->
            <TextBlock x:Name="TxtSectionTwitch" Style="{StaticResource SectionLabel}"
                       Margin="0,20,0,0"/>
            <Rectangle Height="1" Fill="#3D2B5E" Margin="0,4,0,0"/>

            <TextBlock x:Name="TxtTwUrl" Style="{StaticResource FieldLabel}"/>
            <TextBlock x:Name="TxtTwUrlHint" Style="{StaticResource FieldHint}"/>
            <TextBox x:Name="TwitchUrl" Style="{StaticResource InputField}"
                     Text="https://www.twitch.tv/"/>

            <!-- UA: Кнопка збереження / EN: Save button -->
            <Button x:Name="BtnSave"
                    Style="{StaticResource EmpButton}"
                    Margin="0,28,0,0" HorizontalAlignment="Right"
                    Click="BtnSave_Click"/>

        </StackPanel>
    </ScrollViewer>
</Window>