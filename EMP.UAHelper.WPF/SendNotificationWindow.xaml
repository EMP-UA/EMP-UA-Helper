<!-- UA: Вікно надсилання сповіщення — завжди показує приклад перед відправкою,
     окремо для Telegram і Discord, з мініатюрою й м'яким попередженням про
     нерозпізнане посилання.
     EN: Send-notification window — always shows a preview before sending,
     separately for Telegram and Discord, with a thumbnail and a soft warning
     for unrecognized links. -->
<Window x:Class="EMP.UAHelper.WPF.SendNotificationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Height="960" Width="580"
        MinHeight="700" MinWidth="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="#0D0A14">

    <Window.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E8E0F0"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,12,0,3"/>
        </Style>

        <Style x:Key="FieldHint" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#B8A8D0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,3"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="WarningHint" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E0A030"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,2,0,0"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="InputField" TargetType="TextBox">
            <Setter Property="Background" Value="#1A1425"/>
            <Setter Property="Foreground" Value="#E8E0F0"/>
            <Setter Property="BorderBrush" Value="#3D2B5E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="SelectionBrush" Value="#8A46C1"/>
        </Style>

        <Style x:Key="EmpButton" TargetType="Button">
            <Setter Property="Background" Value="#8A46C1"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="24,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#C989F3"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="LangButton" TargetType="Button">
            <Setter Property="Background" Value="#1A1425"/>
            <Setter Property="Foreground" Value="#C989F3"/>
            <Setter Property="BorderBrush" Value="#8A46C1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3D2B5E"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="AutoCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#E8E0F0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,10,0,0"/>
        </Style>

        <Style x:Key="PreviewBox" TargetType="TextBox">
            <Setter Property="Background" Value="#1A1425"/>
            <Setter Property="Foreground" Value="#B8A8D0"/>
            <Setter Property="BorderBrush" Value="#3D2B5E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="MinHeight" Value="70"/>
            <Setter Property="MaxHeight" Value="130"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
        </Style>

        <Style x:Key="PlatformPreviewLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#C989F3"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,10,0,3"/>
        </Style>

        <Style x:Key="PickerToggleButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#C989F3"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="0,8,0,4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#8A46C1"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DarkListBox" TargetType="ListBox">
            <Setter Property="Background" Value="#1A1425"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="4"/>
        </Style>

        <Style x:Key="DarkListBoxItem" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#3D2B5E"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#8A46C1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ComboItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#1A1425"/>
            <Setter Property="Foreground" Value="#E8E0F0"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#3D2B5E"/>
                                <Setter Property="Foreground" Value="#C989F3"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#3D2B5E"/>
                                <Setter Property="Foreground" Value="#C989F3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ComboField" TargetType="ComboBox">
            <Setter Property="Background" Value="#1A1425"/>
            <Setter Property="Foreground" Value="#E8E0F0"/>
            <Setter Property="BorderBrush" Value="#3D2B5E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource ComboItemStyle}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press"
                                          Panel.ZIndex="1">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{Binding BorderBrush, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                BorderThickness="{Binding BorderThickness, RelativeSource={RelativeSource AncestorType=ComboBox}}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="28"/>
                                                </Grid.ColumnDefinitions>
                                                <Path Grid.Column="1"
                                                      Data="M0,0 L4,4 L8,0 Z" Fill="#C989F3"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <ContentPresenter x:Name="ContentSite"
                                               Margin="{TemplateBinding Padding}"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Left"
                                               IsHitTestVisible="False"
                                               Content="{TemplateBinding SelectionBoxItem}"
                                               ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"/>

                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Border Background="#1A1425"
                                        BorderBrush="#8A46C1"
                                        BorderThickness="1"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                        MaxHeight="220">
                                    <ScrollViewer Margin="2" SnapsToDevicePixels="True">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,20,28,24">

            <!-- UA: Заголовок і перемикач мови
                 EN: Header and language switcher -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="TxtHeader"
                           Grid.Column="0"
                           Foreground="#C989F3" FontSize="20" FontWeight="Bold"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="8,0,0,0">
                    <Button x:Name="BtnUA" Content="🇺🇦 UA"
                            Style="{StaticResource LangButton}"
                            Margin="0,0,4,0"
                            Click="BtnUA_Click"/>
                    <Button x:Name="BtnEN" Content="🇬🇧 EN"
                            Style="{StaticResource LangButton}"
                            Click="BtnEN_Click"/>
                </StackPanel>
            </Grid>

            <TextBlock x:Name="TxtDescription"
                       Foreground="#B8A8D0" FontSize="13" Margin="0,6,0,0"
                       TextWrapping="Wrap"/>

            <!-- UA: Чекбокс автопідбору — видимий лише якщо YouTube увімкнено
                 EN: Auto-pick checkbox — visible only if YouTube is enabled -->
            <CheckBox x:Name="ChkAutoLatest" Style="{StaticResource AutoCheckBox}"
                      Visibility="Collapsed"
                      Checked="ChkAutoLatest_Changed" Unchecked="ChkAutoLatest_Changed"/>

            <!-- UA: Мініатюра — з'являється лише коли вдалось розпізнати джерело
                 EN: Thumbnail — appears only when a source is successfully resolved -->
            <Border x:Name="PanelThumbnail" Visibility="Collapsed" Margin="0,12,0,0"
                    Background="#1A1425" BorderBrush="#3D2B5E" BorderThickness="1"
                    HorizontalAlignment="Left">
                <StackPanel>
                    <Image x:Name="PreviewThumbnail" Width="280" Height="158" Stretch="UniformToFill"/>
                    <TextBlock x:Name="TxtThumbnailNote" Style="{StaticResource FieldHint}"
                               Visibility="Collapsed" MaxWidth="280" Margin="8,4,8,6"/>
                </StackPanel>
            </Border>

            <!-- UA: Приклад для Telegram — окремий блок
                 EN: Telegram preview — separate block -->
            <StackPanel x:Name="PanelPreviewTelegram" Visibility="Collapsed">
                <TextBlock x:Name="TxtPreviewTelegramLabel" Style="{StaticResource PlatformPreviewLabel}"/>
                <TextBox x:Name="PreviewTelegramBox" Style="{StaticResource PreviewBox}"/>
            </StackPanel>

            <!-- UA: Приклад для Discord — окремий блок
                 EN: Discord preview — separate block -->
            <StackPanel x:Name="PanelPreviewDiscord" Visibility="Collapsed">
                <TextBlock x:Name="TxtPreviewDiscordLabel" Style="{StaticResource PlatformPreviewLabel}"/>
                <TextBox x:Name="PreviewDiscordBox" Style="{StaticResource PreviewBox}"/>
            </StackPanel>

            <!-- UA: Показується лише якщо жодна платформа сповіщень не увімкнена
                 EN: Shown only if no notification platform is enabled -->
            <TextBlock x:Name="TxtPreviewEmpty" Style="{StaticResource FieldHint}" Visibility="Collapsed"/>

            <!-- UA: Рядок-перемикач списку кандидатів — з'являється лише коли
                     автопідбір знятий
                 EN: Candidate list toggle row — appears only when auto-pick is off -->
            <StackPanel x:Name="PanelPickerRow" Visibility="Collapsed">
                <Button x:Name="BtnTogglePicker" Style="{StaticResource PickerToggleButton}"
                        Click="BtnTogglePicker_Click"/>
                <TextBlock x:Name="TxtPickerHint" Style="{StaticResource FieldHint}"/>
                <TextBlock x:Name="TxtPickerStatus" Style="{StaticResource FieldHint}" Visibility="Collapsed"/>

                <Border x:Name="PanelPickerList" Visibility="Collapsed" Margin="0,4,0,0"
                        BorderBrush="#3D2B5E" BorderThickness="1">
                    <ListBox x:Name="CandidatesList" Style="{StaticResource DarkListBox}"
                             ItemContainerStyle="{StaticResource DarkListBoxItem}"
                             MaxHeight="240"
                             SelectionChanged="CandidatesList_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="72"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="72" Height="40" Background="#0D0A14">
                                        <Image Source="{Binding Thumbnail}" Stretch="UniformToFill"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Title}" Foreground="#E8E0F0"
                                                   FontWeight="SemiBold" FontSize="13" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding SubLabel}" Foreground="#B8A8D0" FontSize="11"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>
            </StackPanel>

            <Rectangle Height="1" Fill="#3D2B5E" Margin="0,16,0,0"/>

            <TextBlock x:Name="TxtTitleLabel" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="TitleInput" Style="{StaticResource InputField}"
                     TextChanged="Field_TextChanged"/>

            <TextBlock x:Name="TxtTypeLabel" Style="{StaticResource FieldLabel}"/>
            <ComboBox x:Name="TypeCombo" Style="{StaticResource ComboField}"
                      SelectionChanged="TypeCombo_SelectionChanged">
                <ComboBoxItem x:Name="ItemLive" Tag="Live"/>
                <ComboBoxItem x:Name="ItemUpcoming" Tag="Upcoming"/>
                <ComboBoxItem x:Name="ItemVideo" Tag="Video"/>
                <ComboBoxItem x:Name="ItemShort" Tag="Short"/>
            </ComboBox>
            <TextBlock x:Name="TxtTypeHint" Style="{StaticResource FieldHint}"/>

            <TextBlock x:Name="TxtUrlLabel" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="UrlInput" Style="{StaticResource InputField}"
                     TextChanged="UrlInput_TextChanged"/>
            <TextBlock x:Name="TxtUrlHint" Style="{StaticResource FieldHint}"/>
            <TextBlock x:Name="TxtUrlWarning" Style="{StaticResource WarningHint}" Visibility="Collapsed"/>

            <!-- UA: Поля дати/часу тепер завжди видимі — підпис змінюється
                     залежно від типу (обов'язкові для Upcoming, довідкові
                     для решти)
                 EN: Date/time fields are now always visible — the label
                     changes depending on type (required for Upcoming,
                     informational for the rest) -->
            <TextBlock x:Name="TxtDateLabel" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="DateInput" Style="{StaticResource InputField}"
                     TextChanged="Field_TextChanged"/>

            <TextBlock x:Name="TxtTimeLabel" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="TimeInput" Style="{StaticResource InputField}"
                     TextChanged="Field_TextChanged"/>

            <Button x:Name="BtnSend"
                    Style="{StaticResource EmpButton}"
                    Margin="0,24,0,0" HorizontalAlignment="Right"
                    Click="BtnSend_Click"/>
        </StackPanel>
    </ScrollViewer>
</Window>